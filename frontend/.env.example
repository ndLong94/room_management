VITE_API_URL=http://localhost:8080
# OAuth (optional – nếu không set thì nút Google/Facebook sẽ ẩn)
# Google: tạo OAuth 2.0 Client ID (Web application) tại https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=
# Facebook: tạo app tại https://developers.facebook.com/, lấy App ID
VITE_FACEBOOK_APP_ID=
