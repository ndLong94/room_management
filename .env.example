# Copy to .env and fill values before: docker compose up -d
# Required
POSTGRES_PASSWORD=your-secure-postgres-password
JWT_SECRET=your-256-bit-secret-at-least-32-chars-long-change-me

# Optional
POSTGRES_DB=room_management
POSTGRES_USER=postgres
HTTP_PORT=80
# CORS: URL user dùng để mở app. BẮT BUỘC đổi khi deploy:
#   - Không domain: http://IP_DROPLET (vd: http://164.92.100.50)
#   - Có domain:    https://yourdomain.com
# Chỉ để localhost khi chạy dev trên máy local.
CORS_ALLOWED_ORIGINS=http://localhost

# OAuth (optional – nếu không set thì đăng nhập Google/Facebook sẽ báo lỗi cấu hình)
# Google: OAuth 2.0 Client ID (Web application) từ https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
# Facebook: App ID và App Secret từ https://developers.facebook.com/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
